{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://azure.cn/archaeologist/schemas/pipeline-validation-1.0.schema.json",
  "title": "Pipeline Validation Projection 1.0",
  "type": "object", "additionalProperties": true,
  "required": ["schema_version", "batch_id", "item_id", "validated_at", "status", "errors", "warnings"],
  "properties": {
    "schema_version": {"const": "1.0"}, "batch_id": {"type": "string"}, "item_id": {"type": "string"},
    "validated_at": {"type": "string", "format": "date-time"}, "status": {"enum": ["passed", "failed"]},
    "errors": {"type": "array", "items": {"$ref": "#/$defs/issue"}}, "warnings": {"type": "array", "items": {"$ref": "#/$defs/issue"}}
  },
  "$defs": {"issue": {"type": "object", "additionalProperties": true, "required": ["code", "message"], "properties": {"code": {"type": "string"}, "message": {"type": "string"}, "path": {"type": "string"}}}}
}
